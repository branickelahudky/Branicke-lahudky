# PostgreSQL databáze
DATABASE_URL="postgresql://user:password@localhost:5432/branicke_lahudky?schema=public"

# NextAuth / autentizace
NEXTAUTH_SECRET="vygeneruj-pomoci-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Platební brána ComGate (CZ)
COMGATE_MERCHANT_ID=""
COMGATE_SECRET=""
COMGATE_TEST_MODE="true"

# Email – Forpsi SMTP
SMTP_HOST=smtp.forpsi.com
SMTP_PORT=465
SMTP_USER=info@lahudkybranik.cz
SMTP_PASSWORD=
# true = přesměruj vše na SMTP_USER (bezpečné pro testování)
EMAIL_TEST_MODE=true

# S3 / R2 pro produktové obrázky
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Provoz
NEXT_PUBLIC_SHOP_NAME="Branické lahůdkářství"
NEXT_PUBLIC_SHOP_URL="https://branickelahudky.cz"
