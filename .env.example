# PostgreSQL databáze
DATABASE_URL="postgresql://user:password@localhost:5432/branicke_lahudky?schema=public"

# NextAuth / autentizace
NEXTAUTH_SECRET="vygeneruj-pomoci-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Přihlášení přes Google (console.cloud.google.com → OAuth 2.0 Client ID)
# Redirect URI: <URL webu>/api/auth/google/callback
# Bez vyplněných klíčů se tlačítko „Pokračovat přes Google" nezobrazuje.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Platební brána ComGate (CZ)
COMGATE_MERCHANT_ID=""
COMGATE_SECRET=""
COMGATE_TEST_MODE="true"

# PayPal (developer.paypal.com → Apps & Credentials)
# Bez vyplněných klíčů se PayPal v pokladně nenabízí (web běží dál).
# PAYPAL_MODE: "sandbox" pro testování, "live" pro ostrý provoz
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"
PAYPAL_CURRENCY="CZK"

# Email – Forpsi SMTP
SMTP_HOST=smtp.forpsi.com
SMTP_PORT=465
SMTP_USER=info@lahudkybranik.cz
SMTP_PASSWORD=
# true = přesměruj vše na SMTP_USER (bezpečné pro testování)
EMAIL_TEST_MODE=true

# S3 / R2 pro produktové obrázky
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Provoz
NEXT_PUBLIC_SHOP_NAME="Branické lahůdkářství"
NEXT_PUBLIC_SHOP_URL="https://branickelahudky.cz"
