// Branické lahůdkářství - databázové schéma
// E-shop pro řeznictví a lahůdkářství
//
// Specifika oproti běžnému e-shopu:
//  - Váhové produkty: finální cena = skutečná navážená váha × cena/kg
//  - Stavy skladu: skladem, na dotaz, vyprodáno, momentálně nedostupné
//  - DPH 12 % na potraviny (CZ od 2024), 21 % na dopravu/platbu
//  - B2B podpora (IČO, DIČ)
//  - Hostovské objednávky (bez registrace)
//  - Snapshot adres a cen v objednávce (cena se mohla od objednání změnit)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────────────────────
// KATEGORIE - hierarchické (Drůbež > Kuřecí, Hovězí > Steak, ...)
// ───────────────────────────────────────────────────────────────

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  imageUrl    String?

  // Hierarchie (self-reference)
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  products Product[]

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  // SEO
  metaTitle       String?
  metaDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([slug])
}

// ───────────────────────────────────────────────────────────────
// PRODUKTY
// ───────────────────────────────────────────────────────────────

model Product {
  id               String  @id @default(cuid())
  sku              String  @unique // interní kód (např. "459")
  slug             String  @unique
  name             String
  shortDescription String?
  description      String? @db.Text

  // Ceny - vždy ukládáme obě (bez DPH i s DPH) kvůli zaokrouhlovacím chybám
  priceWithoutVat Decimal @db.Decimal(10, 2) // cena bez DPH
  priceWithVat    Decimal @db.Decimal(10, 2) // cena s DPH
  vatRate         Decimal @default(12.0) @db.Decimal(5, 2) // potraviny = 12 %

  // Akční cena (pokud běží sleva)
  salePriceWithoutVat Decimal? @db.Decimal(10, 2)
  salePriceWithVat    Decimal? @db.Decimal(10, 2)
  saleStartsAt        DateTime?
  saleEndsAt          DateTime?

  // Váhový režim - pro maso typicky cena za kg, finální cena dle reálné váhy
  // Pokud true, zobrazujeme "od XX Kč" a v košíku se cena přepočítá podle navážení
  isWeightBased Boolean @default(false)
  unit          Unit    @default(KS) // za jakou jednotku je cena

  // Pro váhové produkty - přibližná hmotnost balení (kvůli zobrazení "cca 250g")
  approximateWeightKg Decimal? @db.Decimal(10, 3)

  // Varianty (250g / 500g / 1kg) - když má produkt fixní porce
  variants ProductVariant[]

  // Sklad
  stockQuantity Int         @default(0)
  stockStatus   StockStatus @default(IN_STOCK)
  trackStock    Boolean     @default(true)

  // Zařazení
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  // Štítky (Akce, Novinka, Tip, Výprodej, Viditelnost)
  isOnSale      Boolean @default(false)
  isNew         Boolean @default(false)
  isFeatured    Boolean @default(false)
  isOnClearance Boolean @default(false)

  // Dodavatel / značka (pro Sprint 3-2b)
  supplierName String?
  brandName    String?

  // Obrázky
  images ProductImage[]

  // Potravinářské údaje (povinné dle EU 1169/2011)
  ingredients   String? @db.Text // složení
  allergens     String? // alergeny (zvýrazněné v složení) - legacy string field
  nutritionInfo Json? // výživové hodnoty na 100g - legacy
  origin        String? // země původu - legacy
  storageInfo   String? // podmínky skladování - legacy
  shelfLifeDays Int? // trvanlivost ve dnech od výroby

  // LOGISTIKA
  weightGrams Int?
  lengthMm    Int?
  widthMm     Int?
  heightMm    Int?
  storageTemp StorageTemp @default(ROOM_TEMP)
  isFragile   Boolean     @default(false)

  // PARAMETRY - VÝŽIVA (na 100 g)
  nutritionPer100g Json? // { energyKj, energyKcal, fat, saturatedFat, carbohydrates, sugars, protein, salt, fiber }

  // PARAMETRY - ALERGENY EU 1169/2011
  allergenCodes Json?   // string[] z kódů, např. ["1", "3", "7"]
  allergenInfo  String? // doplňující poznámka o alergenech

  // PARAMETRY - PŮVOD A SLOŽENÍ
  countryOfOrigin String? // kód země, např. "CZ", "IT"
  producerName    String?
  producerAddress String?

  // PARAMETRY - SPOTŘEBA
  useByInstructions   String? // po otevření spotřebovat do...
  storageInstructions String? // skladovací pokyny pro zákazníka

  // Hodnocení
  reviews       Review[]
  averageRating Decimal? @db.Decimal(3, 2)
  reviewCount   Int      @default(0)

  // SEO
  metaTitle       String?
  metaDescription String?

  // SEO
  isIndexable Boolean @default(true) // meta noindex pokud false

  // Stav
  isActive    Boolean   @default(true)
  publishedAt DateTime?

  // Vazby
  orderItems  OrderItem[]
  cartItems   CartItem[]
  relatedFrom ProductRelation[] @relation("RelatedFrom")
  relatedTo   ProductRelation[] @relation("RelatedTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([stockStatus])
  @@index([isActive, publishedAt])
}

enum StorageTemp {
  FROZEN       // mraženo (-18°C a méně)
  REFRIGERATED // chladnička (0-5°C)
  COOL         // chladno (do 14°C)
  ROOM_TEMP    // pokojová teplota (15-25°C)
}

enum Unit {
  KS // kus
  KG // kilogram
  G_100 // 100 gramů
  L // litr
  ML_100 // 100 ml
}

enum StockStatus {
  IN_STOCK // skladem (>5 ks)
  LOW_STOCK // poslední kusy
  OUT_OF_STOCK // vyprodáno
  ON_REQUEST // na dotaz (např. husa - lokální farma)
  TEMPORARILY_UNAVAILABLE // momentálně nedostupné
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name String // "250g", "500g", "1kg"
  sku  String? @unique
  isActive Boolean @default(true)

  weightKg        Decimal? @db.Decimal(10, 3)
  priceWithoutVat Decimal  @db.Decimal(10, 2)
  priceWithVat    Decimal  @db.Decimal(10, 2)

  stockQuantity Int @default(0)
  sortOrder     Int @default(0)

  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([productId])
}

model ProductImage {
  id           String  @id @default(cuid())
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url          String   @default("")
  thumbnailUrl String   @default("")
  storageKey   String   @default("")
  thumbnailKey String   @default("")

  altText      String?
  sortOrder    Int     @default(0)
  isPrimary    Boolean @default(false)

  fileSize     Int     @default(0)
  width        Int     @default(0)
  height       Int     @default(0)
  mimeType     String  @default("image/jpeg")

  createdAt    DateTime @default(now())

  @@index([productId, sortOrder])
}

model ProductRelation {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation("RelatedFrom", fields: [productId], references: [id], onDelete: Cascade)
  relatedId String
  related   Product  @relation("RelatedTo", fields: [relatedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([productId, relatedId])
  @@index([productId])
  @@index([relatedId])
}

// ───────────────────────────────────────────────────────────────
// ZÁKAZNÍCI
// ───────────────────────────────────────────────────────────────

model Customer {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String? // null pro host objednávky / sociální login
  firstName    String
  lastName     String
  phone        String?

  // Import z Shoptetu
  shoptetId    String? @unique
  internalNote String? @db.Text

  // B2B
  isBusinessCustomer Boolean @default(false)
  companyName        String?
  companyId          String? // IČO
  vatId              String? // DIČ

  // Marketing
  acceptsMarketing Boolean @default(false)

  // Účet
  emailVerified DateTime?
  lastLoginAt   DateTime?

  addresses Address[]
  orders    Order[]
  reviews   Review[]
  carts     Cart[]
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([shoptetId])
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type      AddressType @default(SHIPPING)
  label     String? // "Domov", "Práce"
  isDefault Boolean     @default(false)

  firstName  String
  lastName   String
  company    String?
  street     String
  city       String
  postalCode String
  country    String  @default("CZ")
  phone      String?
  note       String? // "Zazvonit dvakrát", "Vchod ze dvora"

  shippingOrders Order[] @relation("OrderShippingAddress")
  billingOrders  Order[] @relation("OrderBillingAddress")

  @@index([customerId])
}

enum AddressType {
  SHIPPING
  BILLING
  BOTH
}

// ───────────────────────────────────────────────────────────────
// DOPRAVA
// ───────────────────────────────────────────────────────────────

model ShippingMethod {
  id          String  @id @default(cuid())
  code        String  @unique // "PRAHA_NEXT_DAY", "PICKUP_BRANIK", "PPL", "ZASILKOVNA"
  name        String
  description String?

  priceWithoutVat Decimal @db.Decimal(10, 2)
  priceWithVat    Decimal @db.Decimal(10, 2)
  vatRate         Decimal @default(21.0) @db.Decimal(5, 2)

  // Doprava zdarma od částky
  freeShippingThreshold Decimal? @db.Decimal(10, 2)

  // Způsob vyzvednutí
  isPickup Boolean @default(false)

  // Předpokládaná doba doručení
  estimatedDays    String? // "ihned", "do druhého dne", "1-2 dny"
  estimatedDaysMin Int?
  estimatedDaysMax Int?

  // Limity
  maxWeightKg Decimal? @db.Decimal(10, 3)
  maxOrderValue Decimal? @db.Decimal(10, 2) // např. dobírka max 50 000

  // Dostupnost
  isActive             Boolean  @default(true)
  sortOrder            Int      @default(0)
  availableCountries   String[] @default(["CZ"])

  // Povolené platby (M:N)
  allowedPaymentMethods PaymentMethodOnShipping[]

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ───────────────────────────────────────────────────────────────
// PLATBY
// ───────────────────────────────────────────────────────────────

model PaymentMethod {
  id          String  @id @default(cuid())
  code        String  @unique // "COD", "CARD_ONLINE", "BANK_TRANSFER", "APPLE_PAY"
  name        String
  description String?

  // Příplatek za platbu (typicky dobírka)
  feeWithoutVat Decimal @default(0) @db.Decimal(10, 2)
  feeWithVat    Decimal @default(0) @db.Decimal(10, 2)
  vatRate       Decimal @default(21.0) @db.Decimal(5, 2)

  // Kategorie pro UI: "card", "transfer", "cash"
  type String?

  // Platební brána
  provider PaymentProvider @default(MANUAL)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  allowedShippingMethods PaymentMethodOnShipping[]
  orders                 Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PaymentProvider {
  MANUAL // hotově/převodem, ručně potvrdit
  STRIPE
  COMGATE
  GOPAY
  THE_PAY
}

// M:N tabulka - která platba je dostupná pro kterou dopravu
model PaymentMethodOnShipping {
  shippingMethodId String
  shippingMethod   ShippingMethod @relation(fields: [shippingMethodId], references: [id], onDelete: Cascade)
  paymentMethodId  String
  paymentMethod    PaymentMethod  @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@id([shippingMethodId, paymentMethodId])
}

// ───────────────────────────────────────────────────────────────
// KOŠÍK (perzistentní, pro přihlášené i hosty přes session)
// ───────────────────────────────────────────────────────────────

model Cart {
  id        String  @id @default(cuid())
  sessionId String? @unique // pro nepřihlášené (cookie)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  items CartItem[]

  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([customerId])
}

model CartItem {
  id     String @id @default(cuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity Int

  createdAt DateTime @default(now())

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

// ───────────────────────────────────────────────────────────────
// OBJEDNÁVKY
// ───────────────────────────────────────────────────────────────

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique // "26000123" (rok + pořadové)

  // Zákazník (nullable kvůli host objednávkám)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Kontakt pro host objednávky
  contactEmail     String
  contactPhone     String
  contactFirstName String
  contactLastName  String

  // B2B
  isBusinessOrder Boolean @default(false)
  companyName     String?
  companyId       String? // IČO
  vatId           String? // DIČ

  // Stavy
  status            OrderStatus       @default(PENDING)
  paymentStatus     PaymentStatus     @default(UNPAID)
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED)

  // Položky
  items OrderItem[]

  // Adresy (FK + JSON snapshot pro případ smazání)
  shippingAddressId       String?
  shippingAddress         Address? @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])
  shippingAddressSnapshot Json // vždy uložit snapshot

  billingAddressId       String?
  billingAddress         Address? @relation("OrderBillingAddress", fields: [billingAddressId], references: [id])
  billingAddressSnapshot Json?

  // Doprava
  shippingMethodId        String?
  shippingMethod          ShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  shippingMethodName      String // snapshot
  shippingPriceWithoutVat Decimal         @default(0) @db.Decimal(10, 2)
  shippingPriceWithVat    Decimal         @default(0) @db.Decimal(10, 2)

  // Termín doručení (typické pro lahůdky - "doručit ve čtvrtek")
  preferredDeliveryDate DateTime?
  deliveryTimeSlot      String? // "9-12", "12-18"
  deliveryNote          String?

  // Platba
  paymentMethodId      String?
  paymentMethod        PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  paymentMethodName    String // snapshot
  paymentFeeWithoutVat Decimal        @default(0) @db.Decimal(10, 2)
  paymentFeeWithVat    Decimal        @default(0) @db.Decimal(10, 2)

  // Slevový kód
  discountCodeId String?
  discountCode   DiscountCode? @relation(fields: [discountCodeId], references: [id])
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)

  // Souhrn - vždy ukládat všechny varianty
  subtotalWithoutVat Decimal @db.Decimal(10, 2) // mezisoučet zboží bez DPH
  subtotalWithVat    Decimal @db.Decimal(10, 2)
  totalVat           Decimal @db.Decimal(10, 2) // celkem DPH
  totalWithoutVat    Decimal @db.Decimal(10, 2) // celkem bez DPH (vč. dopravy a platby)
  totalWithVat       Decimal @db.Decimal(10, 2) // celkem k úhradě

  // Poznámky
  customerNote String?
  internalNote String? // interní poznámka pro obsluhu

  // Tracking
  trackingNumber String?
  trackingUrl    String?

  // Platba
  paymentTransactionId String?
  paidAt               DateTime?

  // Životní cyklus
  confirmedAt        DateTime?
  preparedAt         DateTime?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  // Faktura
  invoiceNumber   String? @unique
  invoiceIssuedAt DateTime?
  invoiceUrl      String?

  notes     OrderNote[]
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING // čeká na zpracování
  CONFIRMED // potvrzená
  PROCESSING // zpracovává se (krájí se, balí se)
  READY // připraveno k vyzvednutí/odeslání
  SHIPPED // odesláno
  DELIVERED // doručeno
  CANCELLED // zrušeno
  REFUNDED // vráceno
}

enum PaymentStatus {
  UNPAID
  PENDING // čeká na potvrzení od brány
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIALLY_FULFILLED
  FULFILLED
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  // SNAPSHOT v čase objednávky (cena/název se mohou změnit)
  productName String
  productSku  String
  variantName String?
  imageUrl    String?

  // Množství
  quantity         Int // počet kusů
  actualWeightKg   Decimal? @db.Decimal(10, 3) // skutečná navážená váha (vyplní obsluha při krájení)
  expectedWeightKg Decimal? @db.Decimal(10, 3) // přibližná - co zákazník objednal

  // Ceny - snapshot v okamžiku objednání
  unitPriceWithoutVat Decimal @db.Decimal(10, 2)
  unitPriceWithVat    Decimal @db.Decimal(10, 2)
  vatRate             Decimal @db.Decimal(5, 2)
  unit                Unit

  // Mezisoučty pro tuto položku
  lineTotalWithoutVat Decimal @db.Decimal(10, 2)
  lineTotalWithVat    Decimal @db.Decimal(10, 2)
  lineVatAmount       Decimal @db.Decimal(10, 2)

  isWeightAdjusted Boolean @default(false) // true po navážení

  fulfilledQuantity Int       @default(0)
  fulfilledAt       DateTime?
  fulfilledBy       String?

  itemNote String?  @db.Text
  discount Decimal? @db.Decimal(5, 2)

  @@index([orderId])
  @@index([productId])
}

// ───────────────────────────────────────────────────────────────
// SLEVY
// ───────────────────────────────────────────────────────────────

model DiscountCode {
  id          String  @id @default(cuid())
  code        String  @unique
  description String?

  type  DiscountType
  value Decimal      @db.Decimal(10, 2) // % nebo Kč

  // Podmínky
  minOrderValue Decimal? @db.Decimal(10, 2)
  maxUses       Int?
  maxUsesPerCustomer Int? @default(1)
  usedCount     Int      @default(0)

  // Platnost
  validFrom  DateTime?
  validUntil DateTime?

  isActive Boolean @default(true)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

// ───────────────────────────────────────────────────────────────
// HODNOCENÍ
// ───────────────────────────────────────────────────────────────

model Review {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  authorName String
  rating     Int // 1-5
  title      String?
  content    String? @db.Text

  isApproved   Boolean @default(false)
  isPurchaseVerified Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([productId])
}

// ───────────────────────────────────────────────────────────────
// ADMIN
// ───────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

model AdminUser {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  role         AdminRole  @default(STAFF)

  isActive    Boolean    @default(true)
  status      UserStatus @default(ACTIVE)
  lastLoginAt DateTime?
  lastLoginIp String?

  invitedById String?
  invitedBy   AdminUser?  @relation("InvitedBy", fields: [invitedById], references: [id])
  invitedAt   DateTime?
  invitedUsers AdminUser[] @relation("InvitedBy")

  sessions      AdminSession[]
  orderNotes    OrderNote[]
  invitations   AdminInvitation[]
  auditLogs     AdminAuditLog[]
  targetAudits  AdminAuditLog[]    @relation("AuditTarget")
  resetTokens   PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminSession {
  id          String    @id @default(cuid())
  token       String    @unique
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  ipAddress String?
  userAgent String?

  @@index([adminUserId])
  @@index([token])
}

model AdminInvitation {
  id          String    @id @default(cuid())
  email       String
  role        AdminRole
  token       String    @unique
  invitedById String
  invitedBy   AdminUser @relation(fields: [invitedById], references: [id])
  invitedAt   DateTime  @default(now())
  expiresAt   DateTime
  acceptedAt  DateTime?
  cancelledAt DateTime?

  @@index([token])
  @@index([email])
}

model AdminAuditLog {
  id           String    @id @default(cuid())
  userId       String?
  user         AdminUser? @relation(fields: [userId], references: [id])
  action       String
  targetUserId String?
  targetUser   AdminUser? @relation("AuditTarget", fields: [targetUserId], references: [id])
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
}

enum AdminRole {
  OWNER // majitel - vše vč. financí
  ADMIN // správce - vše kromě financí
  STAFF // obsluha - jen objednávky a sklad
}

// ───────────────────────────────────────────────────────────────
// INTERNÍ POZNÁMKY K OBJEDNÁVKÁM
// ───────────────────────────────────────────────────────────────

model OrderNote {
  id        String     @id @default(cuid())
  orderId   String
  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  content   String     @db.Text
  createdBy String?
  adminUser AdminUser? @relation(fields: [createdBy], references: [id])
  createdAt DateTime   @default(now())

  @@index([orderId])
}

// ───────────────────────────────────────────────────────────────
// NASTAVENÍ DODAVATELE (single-row config)
// ───────────────────────────────────────────────────────────────

model SupplierSettings {
  id          String  @id @default(cuid())
  companyName String
  street      String
  city        String
  postalCode  String
  country     String  @default("Česká republika")
  companyId   String  // IČO
  vatId       String? // DIČ (null = neplátce DPH)
  isVatPayer  Boolean @default(true)
  bankAccount String?
  iban        String?
  legalNote   String?
  logoUrl     String?
  invoiceFooterNote String?
  defaultDueDays    Int @default(14)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ───────────────────────────────────────────────────────────────
// NASTAVENÍ PROVOZOVNY (single-row config)
// ───────────────────────────────────────────────────────────────

model BranchSettings {
  id           String  @id @default(cuid())
  name         String
  street       String
  zip          String
  city         String
  country      String  @default("Česká republika")
  email        String?
  phone1       String?
  phone2       String?
  managerName  String?
  openingHours String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ───────────────────────────────────────────────────────────────
// ČÍSELNÉ ŘADY
// ───────────────────────────────────────────────────────────────

model NumberSeries {
  id            String  @id @default(cuid())
  key           String  @unique  // "INVOICE", "ORDER", "CREDIT_NOTE", "PROFORMA", "DELIVERY_NOTE"
  name          String
  format        String           // "{rok}-{poradi:3}", "OBJ-{rok}-{poradi:3}", …
  currentYear   Int
  currentNumber Int
  yearlyReset   Boolean @default(true)
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ───────────────────────────────────────────────────────────────
// NASTAVENÍ BRANDU (barvy emailů a dokumentů)
// ───────────────────────────────────────────────────────────────

model BrandSettings {
  id           String @id @default(cuid())
  primaryColor String @default("#C9A961")
  darkColor    String @default("#0a0a0a")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ───────────────────────────────────────────────────────────────
// NASTAVENÍ DANÍ (single-row config + sazby DPH)
// ───────────────────────────────────────────────────────────────

model TaxSettings {
  id                        String  @id @default(cuid())
  isVatPayer                Boolean @default(true)
  defaultPricesIncludeVat   Boolean @default(true)
  defaultB2BPricesIncludeVat Boolean @default(false)
  defaultCountry            String  @default("CZ")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VatRate {
  id          String   @id @default(cuid())
  code        String   @unique  // "STANDARD", "REDUCED", "ZERO"
  name        String
  rate        Decimal  @db.Decimal(5, 2)
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ───────────────────────────────────────────────────────────────
// DOKLADY (faktury, dobropisy, zálohy, …)
// ───────────────────────────────────────────────────────────────

enum DocumentType {
  INVOICE          // Daňový doklad (faktura)
  PROFORMA         // Zálohová faktura
  CREDIT_NOTE      // Dobropis
  DELIVERY_NOTE    // Dodací list
  PAYMENT_RECEIPT  // Daňový doklad k přijaté platbě
}

enum DocumentStatus {
  VALID
  CANCELLED
}

model Document {
  id     String         @id @default(cuid())
  type   DocumentType
  status DocumentStatus @default(VALID)
  number String         @unique // "2026-01", "Z2026-01", …

  // Vazby (volitelné)
  orderId    String?
  order      Order?    @relation(fields: [orderId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Snapshot dodavatele
  supplierName        String
  supplierStreet      String
  supplierCity        String
  supplierPostalCode  String
  supplierCountry     String
  supplierCompanyId   String
  supplierVatId       String?
  supplierBankAccount String?
  supplierLegalNote   String?

  // Snapshot odběratele
  customerName        String
  customerStreet      String?
  customerCity        String?
  customerPostalCode  String?
  customerCountry     String?
  customerCompanyId   String?
  customerVatId       String?
  customerEmail       String?
  customerPhone       String?

  // Datumy
  issueDate DateTime
  dueDate   DateTime
  taxDate   DateTime // DUZP

  // Platba
  variableSymbol  String
  constantSymbol  String?
  specificSymbol  String?
  paymentMethod   String

  // Cenový režim
  pricesIncludeVat Boolean @default(false)

  // Součty
  subtotalWithoutVat Decimal @db.Decimal(12, 2)
  totalVat           Decimal @db.Decimal(12, 2)
  totalWithVat       Decimal @db.Decimal(12, 2)

  // Rozpis DPH: [{ rate: 12, base: 100.00, vat: 12.00 }, …]
  vatBreakdown Json

  items DocumentItem[]

  note         String? @db.Text
  internalNote String? @db.Text
  createdBy    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([number])
  @@index([orderId])
  @@index([customerId])
  @@index([issueDate])
}

model DocumentItem {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  description         String
  quantity            Decimal @db.Decimal(10, 3)
  unit                String                       // "kg", "ks"
  unitPriceWithoutVat Decimal @db.Decimal(12, 2)
  unitPriceWithVat    Decimal @db.Decimal(12, 2)
  vatRate             Int                          // 12 nebo 21
  discount            Decimal? @db.Decimal(5, 2)

  lineTotalWithoutVat Decimal @db.Decimal(12, 2)
  lineVatAmount       Decimal @db.Decimal(12, 2)
  lineTotalWithVat    Decimal @db.Decimal(12, 2)

  sortOrder Int @default(0)

  @@index([documentId])
}

model EmailLog {
  id         String   @id @default(cuid())
  orderId    String?
  customerId String?
  recipient  String
  subject    String
  status     String   // "sent" | "failed"
  error      String?
  sentAt     DateTime @default(now())

  @@index([orderId])
  @@index([sentAt])
}

model OrderStatusConfig {
  id     String      @id @default(cuid())
  status OrderStatus @unique
  label  String
  color  String      @default("#6b7280")
  sortOrder Int      @default(0)

  sendEmail    Boolean @default(false)
  emailSubject String?
  emailHeading String?
  emailBody    String? @db.Text

  generateInvoice Boolean @default(false)
  attachInvoice   Boolean @default(false)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ───────────────────────────────────────────────────────────────
// STATICKÉ STRÁNKY (CMS)
// ───────────────────────────────────────────────────────────────

model Page {
  id              String  @id @default(cuid())
  slug            String  @unique
  title           String
  content         String? @db.Text
  excerpt         String?
  isPublished     Boolean @default(false)
  metaTitle       String?
  metaDescription String?
  robotsIndex     Boolean @default(true)
  sortOrder       Int     @default(0)
  isSystem        Boolean @default(false) // systémové stránky nelze smazat

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
}
